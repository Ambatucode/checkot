rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // HELPER FUNCTIONS
    // ============================================================

    // Returns true if the request is from a logged-in user
    function isSignedIn() {
      return request.auth != null;
    }

    // Returns the full user document data from Firestore
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    // Returns true if the current user is a shop owner
    function isOwner() {
      return isSignedIn()
        && getUserData(request.auth.uid).role == 'owner';
    }

    // Returns true if the current user owns a specific shop
    function ownsShop(shopId) {
      return isOwner()
        && getUserData(request.auth.uid).ownedShopId == shopId;
    }

    // Returns true if the current user is a super admin
    function isAdmin() {
      return isSignedIn()
        && getUserData(request.auth.uid).role == 'admin';
    }

    // Returns true if the request only contains allowed fields
    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys()
        .hasOnly(allowedFields);
    }

    // Returns true if no forbidden fields are being changed
    function isNotChanging(forbiddenFields) {
      return request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasAll(forbiddenFields) == false;
    }

    // Validates that a value is a positive number
    function isPositiveNumber(value) {
      return value is number && value > 0;
    }

    // Returns true if the given shop exists and is approved/active.
    // Prevents booking against a fake, pending, or rejected shopId.
    function shopIsActive(shopId) {
      return exists(/databases/$(database)/documents/shop_services/$(shopId))
        && get(/databases/$(database)/documents/shop_services/$(shopId)).data.status == 'active';
    }

    // ============================================================
    // USERS COLLECTION
    // ============================================================
    match /users/{userId} {

      // --- READ ---
      // Users can read their own profile
      // Owners can read any profile (needed for customer list)
      // Admins can read any profile (needed for approval dashboard)
      allow read: if isSignedIn()
        && (request.auth.uid == userId || isOwner() || isAdmin());

      // --- CREATE ---
      // Only during signup, user must match their UID
      // Must start as 'customer' or as 'owner' with a valid ownedShopId
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.userId == userId
        && (
          request.resource.data.role == 'customer'
          ||
          (request.resource.data.role == 'owner'
           && request.resource.data.ownedShopId is string
           && request.resource.data.ownedShopId != '')
        );

      // --- UPDATE ---
      // Users can update their own profile
      // Cannot change: role, userId, ownedShopId (prevents privilege escalation)
      // savedCars is capped to match the app's own 5-car limit
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && isNotChanging(['role', 'userId', 'ownedShopId'])
        && request.resource.data.savedCars.size() <= 5;

      // --- DELETE ---
      // Nobody can delete accounts from the client
      allow delete: if false;
    }

    // ============================================================
    // BOOKINGS COLLECTION
    // ============================================================
    match /bookings/{bookingId} {

      // --- READ ---
      // Customers see only their own bookings
      // Owners see only bookings for their shop
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid
         || ownsShop(resource.data.shopId));

      // --- CREATE ---
      // Customer must book as themselves, start as PENDING
      // Price must be positive, required fields must exist
      // Shop must actually exist and be approved/active (blocks booking
      // against a fake or not-yet-approved shopId)
      // Services list and price are sanity-bounded — Firestore rules can't
      // sum a list to verify the price matches the shop's per-service
      // pricing, so this is a guardrail, not a full price check.
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'PENDING'
        && request.resource.data.shopId is string
        && request.resource.data.shopId != ''
        && shopIsActive(request.resource.data.shopId)
        && request.resource.data.services is list
        && request.resource.data.services.size() > 0
        && request.resource.data.services.size() <= 20
        && isPositiveNumber(request.resource.data.price)
        && request.resource.data.price <= 1000000;

      // --- UPDATE (Customer) ---
      // Customer can only CANCEL their own PENDING or CONFIRMED booking
      // Can only change the 'status' and 'cancelledAt' fields
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.status == 'CANCELLED'
        && (resource.data.status == 'PENDING'
         || resource.data.status == 'CONFIRMED')
        && (request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasOnly(['status', 'cancelledAt']));

      // --- UPDATE (Owner) ---
      // Owner can advance status for their own shop's bookings
      // Can only change 'status' and the corresponding timestamp
      allow update: if ownsShop(resource.data.shopId)
        && (request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasOnly(['status', 'confirmedAt',
                      'inProgressAt', 'completedAt',
                      'cancelledAt']));

      // --- DELETE ---
      // Nobody can hard-delete bookings from the client
      allow delete: if false;
    }

    // ============================================================
    // SHOP SERVICES COLLECTION
    //   Stores each shop's available services, pricing, and logo.
    //   Any signed-in user can read (clients see available services).
    //   Only the shop owner can write.
    // ============================================================
    match /shop_services/{shopId} {

      // --- READ ---
      // Any authenticated user can read shop services
      allow read: if isSignedIn();

      // --- CREATE ---
      // Only the owner of this shop can create
      // Must start as 'pending' — prevents an owner from self-approving
      // their shop and skipping SuperAdmin review
      allow create: if ownsShop(shopId)
        && request.resource.data is map
        && request.resource.data.keys().hasAll(['services'])
        && request.resource.data.services is list
        && request.resource.data.status == 'pending';

      // --- UPDATE ---
      // Owner can update their shop (prices, services, logo, etc.)
      // but CANNOT change the 'status' field
      // Admin can ONLY change the 'status' field (approve/reject)
      // bayCount is bounded to match the app's own stepper limit (1-10)
      allow update: if (ownsShop(shopId)
        && isNotChanging(['status'])
        && request.resource.data.services is list
        && request.resource.data.services.size() <= 50
        && request.resource.data.bayCount is number
        && request.resource.data.bayCount >= 1
        && request.resource.data.bayCount <= 10)
        || (isAdmin()
          && request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['status']));

      // --- DELETE ---
      // Nobody deletes shops from the client
      allow delete: if false;
    }

    // ============================================================
    // DAY SLOTS COLLECTION
    //   Per-shop-per-day bay reservation ledger (day_slots/{shopId}_{date}).
    //   Used transactionally by booking create/cancel so the check-and-
    //   reserve can be atomic — Firestore transactions can't run queries,
    //   so this document stands in for "query every booking for this
    //   shop+date". Like bookings.price, this can't be fully validated
    //   here (no list-sum support in rules), so this is a guardrail
    //   against garbage writes, not a full correctness check.
    // ============================================================
    match /day_slots/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.resource.data.shopId is string
        && request.resource.data.shopId != ''
        && request.resource.data.entries is list;
      allow delete: if false;
    }

    // ============================================================
    // DENY EVERYTHING ELSE BY DEFAULT
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
