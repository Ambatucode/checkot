rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────
    // HELPER FUNCTIONS
    // ─────────────────────────────────────────────────────────────

    // Returns true if the request is from a logged-in user
    function isSignedIn() {
      return request.auth != null;
    }

    // Returns the full user document from Firestore
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    // Returns true if the current user is an owner
    function isOwner() {
      return isSignedIn() && getUserData(request.auth.uid).role == 'owner';
    }

    // Returns true if the current user owns a specific shop
    function ownsShop(shopId) {
      return isOwner() && getUserData(request.auth.uid).ownedShopId == shopId;
    }

    // ─────────────────────────────────────────────────────────────
    // USERS COLLECTION
    // ─────────────────────────────────────────────────────────────
    match /users/{userId} {

      // Any signed-in user can read their OWN profile
      allow read: if isSignedIn() && request.auth.uid == userId;

      // Owners can read any user profile (needed to show customer list)
      allow read: if isOwner();

      // A user can only create their OWN document, and cannot set role to 'owner'
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.role == 'customer';

      // A user can only update their OWN document
      // SECURITY: They cannot change their role, userId, or ownedShopId
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && !('role' in request.resource.data.diff(resource.data).affectedKeys())
        && !('userId' in request.resource.data.diff(resource.data).affectedKeys())
        && !('ownedShopId' in request.resource.data.diff(resource.data).affectedKeys());

      // Nobody can delete a user document from the client
      allow delete: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // BOOKINGS COLLECTION
    // ─────────────────────────────────────────────────────────────
    match /bookings/{bookingId} {

      // A customer can only read their OWN bookings
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;

      // An owner can read bookings for their OWN shop only
      allow read: if ownsShop(resource.data.shopId);

      // A customer can CREATE a booking only if:
      // - userId must match their own UID (can't book as someone else)
      // - status must start as PENDING (can't self-approve)
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'PENDING';

      // A customer can CANCEL only their own PENDING or CONFIRMED booking
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.status == 'CANCELLED'
        && (resource.data.status == 'PENDING' || resource.data.status == 'CONFIRMED')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);

      // An owner can update status for bookings in their OWN shop only
      // They can ONLY change the status field, nothing else
      allow update: if ownsShop(resource.data.shopId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);

      // Nobody can hard-delete a booking from the client
      allow delete: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // DENY EVERYTHING ELSE BY DEFAULT
    // ─────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
