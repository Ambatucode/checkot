<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Checkot" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <!-- Your normal app theme (for after splash) -->
    <style name="Theme.Checkot.App" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowBackground">@color/checkot_navy</item>
        <item name="android:statusBarColor">@color/checkot_navy</item>
        <item name="android:navigationBarColor">@color/checkot_navy</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
